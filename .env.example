# Database
DATABASE_URL="postgresql://safeher:safeher_dev@localhost:5432/safeher?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (identity vault - 32 byte hex key)
IDENTITY_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# Web
